# API
PORT=3000
DATABASE_URL=postgres://ridenow:ridenow@localhost:5432/ridenow
# development | production — production rejects placeholder/dev secrets at boot
APP_ENV=development

# Geo (OpenStreetMap, keyless)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org

# Passwordless rider auth (phone-OTP). JWT_SECRET falls back to a dev value in
# non-production; it is REQUIRED (and must be strong) when APP_ENV=production.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_SEND_WINDOW_SECONDS=3600
OTP_SEND_MAX=5

# Locked upfront quote lifetime before confirmation (10 minutes)
QUOTE_TTL_SECONDS=600

# OTP (Twilio) — when unset in dev, OTPs are logged to the API console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Payments (Stripe). STRIPE_MODE (test|live) is asserted at boot against the
# secret key's own livemode (sk_test_ vs sk_live_) — a mismatch refuses to start.
PAYMENTS_DRIVER=fake
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Web apps
NEXT_PUBLIC_API_URL=http://localhost:3000
